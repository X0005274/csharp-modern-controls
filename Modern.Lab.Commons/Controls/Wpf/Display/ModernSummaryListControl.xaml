<UserControl x:Class="Modern.Lab.Controls.Wpf.Display.ModernSummaryListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="320" d:DesignHeight="88">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/ControlParts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 제목과 줄바꿈되는 칩 목록을 한 행(제목 왼쪽, 칩 오른쪽)으로 배치한
         카드 표면: 공용 파츠(Parts.CardSurfaceStyle)에 이 컨트롤 고유의
         Padding(16,8)만 덮는다. Flat=True이면 크롬을 제거한다(Flat 트리거의
         Padding=0은 스타일 트리거라 파생 setter보다 우선한다). -->
    <Border>
        <Border.Style>
            <Style TargetType="Border" BasedOn="{StaticResource Parts.CardSurfaceStyle}">
                <Setter Property="Padding" Value="16,8" />
            </Style>
        </Border.Style>
        <DockPanel VerticalAlignment="Center">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding Title, ElementName=RootControl}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Label}">
                        <Style.Triggers>
                            <!-- 제목이 설정되지 않으면 캡션을 완전히 숨긴다 -->
                            <DataTrigger Binding="{Binding Title, ElementName=RootControl}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <ItemsControl x:Name="ChipItems" VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <!-- 항목별 색(ColorMemberPath)이 있으면 그 브러시를, 없으면(null)
                         TargetNullValue로 기본 토큰 색을 쓴다. -->
                    <DataTemplate>
                        <Border CornerRadius="{StaticResource Radius.Pill}"
                                Background="{Binding Background, TargetNullValue={StaticResource Brush.NeutralBackground}}"
                                Padding="10,2"
                                Margin="0,1,6,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Label}"
                                           FontSize="{StaticResource Font.Size.Helper}"
                                           Foreground="{Binding LabelForeground, TargetNullValue={StaticResource Brush.NeutralText}}"
                                           VerticalAlignment="Center"
                                           LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                                <TextBlock Text="{Binding Count}"
                                           FontSize="{StaticResource Font.Size.Helper}"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding CountForeground, TargetNullValue={StaticResource Brush.SelectedText}}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>
