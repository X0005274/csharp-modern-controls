<UserControl x:Class="Modern.Lab.Controls.Wpf.Display.ModernKpiCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="160" d:DesignHeight="72">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/ControlParts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 카드 표면: 공용 파츠(Parts.CardSurfaceStyle) — 큰 반경(카드 8),
         Flat=True이면 공용 카드 패널 위에서 쓰도록 크롬을 제거한다. -->
    <Border Style="{StaticResource Parts.CardSurfaceStyle}">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding Title, ElementName=RootControl}"
                       Style="{StaticResource Text.Label}"
                       LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
            <TextBlock Text="{Binding Value, ElementName=RootControl}"
                       FontSize="{StaticResource Font.Size.Heading}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,2,0,0"
                       LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}" />
        </StackPanel>
    </Border>
</UserControl>
