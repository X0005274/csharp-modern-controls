<UserControl x:Class="Modern.Lab.Controls.Wpf.Display.ModernKpiCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="160" d:DesignHeight="72">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Card surface: large radius per token rule (controls 4 / cards 8) -->
    <Border CornerRadius="{StaticResource Radius.Lg}"
            Background="{StaticResource Brush.Surface}"
            BorderBrush="{StaticResource Brush.BorderSubtle}"
            BorderThickness="1"
            Padding="16,10">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="{Binding Title, ElementName=RootControl}"
                       Style="{StaticResource Text.Label}" />
            <TextBlock Text="{Binding Value, ElementName=RootControl}"
                       FontSize="{StaticResource Font.Size.Heading}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.TextPrimary}"
                       Margin="0,2,0,0" />
        </StackPanel>
    </Border>
</UserControl>
