<UserControl x:Class="Modern.Lab.Controls.Wpf.Input.ModernDatePickerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:Modern.Lab.Controls.Wpf.Common"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="ClearType"
             UseLayoutRounding="True"
             x:Name="RootControl"
             FontFamily="{DynamicResource Font.Family}"
             d:DesignWidth="130" d:DesignHeight="32">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/Tokens.xaml" />
                <common:SharedResourceDictionary Source="/Modern.Lab.Commons;component/Themes/ControlParts.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- 마스크 입력 방식 날짜 필드: 숫자만 치면 yyyy-MM-dd로 자동 형식화되고
         (구분자는 코드가 삽입), 달력 버튼으로 팝업 선택도 가능하다.
         WPF 기본 DatePicker는 직접 입력 파싱이 까다로워 사용하지 않는다.
         필드 표면(hover/포커스/비활성 반응)은 공용 Parts.FieldBorderStyle을 쓴다. -->
    <Border x:Name="OuterBorder"
            Style="{StaticResource Parts.FieldBorderStyle}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 입력 전 형식 안내 플레이스홀더: 에디터가 비어 있는 동안 회색으로 표시 -->
            <TextBlock x:Name="PlaceholderLabel"
                       Grid.Column="0"
                       Text="{Binding Placeholder, ElementName=RootControl}"
                       Margin="{StaticResource Pad.Field}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Parts.PlaceholderTextStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=InnerTextBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 날짜 에디터: 숫자 8자리 → yyyy-MM-dd 자동 마스크.
                 어떤 위치를 고쳐도 TextChanged에서 즉시 재형식화된다. -->
            <TextBox x:Name="InnerTextBox"
                     Grid.Column="0"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="{StaticResource Pad.Field}"
                     VerticalContentAlignment="Center"
                     LayoutTransform="{Binding Path=(common:FontWidthScaling.TextWidthTransform), RelativeSource={RelativeSource Self}}"
                     FontSize="{StaticResource Font.Size.Body}"
                     Foreground="{StaticResource Brush.TextPrimary}"
                     MaxLength="10"
                     TextChanged="InnerTextBox_TextChanged"
                     LostKeyboardFocus="InnerTextBox_LostKeyboardFocus" />

            <!-- 필수 미입력 점: Required이면서 값이 비어 있는 동안만 오른쪽에 표시 -->
            <Border x:Name="RequiredDot"
                    Grid.Column="0"
                    Margin="0,0,6,0">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource Parts.RequiredDotStyle}">
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding Required, ElementName=RootControl}" Value="True" />
                                    <Condition Binding="{Binding Visibility, ElementName=PlaceholderLabel}" Value="Visible" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
            </Border>

            <!-- 달력 팝업 버튼 -->
            <Button x:Name="CalendarButton" Grid.Column="1" Focusable="False" Cursor="Hand"
                    Click="CalendarButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="6,0,10,0">
                            <TextBlock x:Name="CalendarGlyph"
                                       Text="&#xE787;"
                                       FontFamily="{StaticResource Font.Family.Icon}"
                                       FontSize="{StaticResource Font.Size.Icon}"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.TextSecondary}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CalendarGlyph" Property="Foreground" Value="{StaticResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Popup x:Name="CalendarPopup"
                   PlacementTarget="{Binding ElementName=OuterBorder}"
                   Placement="Bottom"
                   AllowsTransparency="True"
                   StaysOpen="False">
                <Border Background="{StaticResource Brush.Surface}"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource Radius.Sm}"
                        Margin="0,2,0,0">
                    <Calendar x:Name="PickerCalendar"
                              DisplayDateStart="{Binding MinDate, ElementName=RootControl}"
                              DisplayDateEnd="{Binding MaxDate, ElementName=RootControl}"
                              SelectedDatesChanged="PickerCalendar_SelectedDatesChanged" />
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
