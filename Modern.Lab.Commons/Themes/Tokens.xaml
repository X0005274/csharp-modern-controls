<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- ============================================================= -->
    <!-- 디자인 토큰 — 모던하고 보수적인 엔터프라이즈 데스크톱 테마.      -->
    <!-- 컨트롤은 반드시 이 토큰을 사용하고 hex/px/굵기를 하드코딩하지 않는다. -->
    <!--                                                                 -->
    <!-- 팔레트는 세 가지 계열로 축소되어 있다:                           -->
    <!--   Primary  — Fluent 액센트 램프 하나 (액션, 선택, 포커스)         -->
    <!--   Neutral  — 쿨 그레이 램프 하나 (텍스트, 서피스, 테두리, 상태)   -->
    <!--   Semantic — Success / Warning / Error / Info 상태 색상 쌍       -->
    <!-- ============================================================= -->

    <!-- 1. 간격 스케일(4px 그리드). 레이아웃 간격/패딩은 이 값을 사용하며, 그리드를 벗어나지 않는다. -->
    <sys:Double x:Key="Space.Xs">4</sys:Double>
    <sys:Double x:Key="Space.Sm">8</sys:Double>
    <sys:Double x:Key="Space.Md">12</sys:Double>
    <sys:Double x:Key="Space.Lg">16</sys:Double>
    <sys:Double x:Key="Space.Xl">24</sys:Double>

    <!-- 2. 크기 — 단일 밀도: Compact(32). 입력, 버튼, 그리드 행이 동일한 컨트롤 높이를
         공유하므로 필드/버튼이 한 줄로 그리드에 정렬된다. -->
    <sys:Double x:Key="Size.ControlHeight">32</sys:Double>
    <sys:Double x:Key="Size.RowHeight">32</sys:Double>
    <sys:Double x:Key="Size.GridHeaderHeight">36</sys:Double>
    <sys:Double x:Key="Size.FocusThickness">1.5</sys:Double>

    <!-- 파생 레이아웃 토큰 -->
    <Thickness x:Key="Pad.Field">12,0</Thickness>
    <Thickness x:Key="Pad.Item">12,6</Thickness>
    <Thickness x:Key="Pad.Button">16,0</Thickness>
    <Thickness x:Key="Gap.Label">0,0,0,8</Thickness>
    <Thickness x:Key="Gap.Helper">0,4,0,0</Thickness>

    <!-- 3. 모서리 반경(Fluent). Sm/Md는 의도적으로 4를 공유(컨트롤); 카드는 8. -->
    <CornerRadius x:Key="Radius.Sm">4</CornerRadius>
    <CornerRadius x:Key="Radius.Md">4</CornerRadius>
    <CornerRadius x:Key="Radius.Lg">8</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">10</CornerRadius>

    <!-- 4. 색상 — Primary (액센트). Windows 11(WinUI 3) 순정 라이트 팔레트:
         액센트 채움은 SystemAccentColorDark1(#005FB8), 호버는 시스템 액센트(#0078D4),
         눌림은 한 톤 아래 — Win11 표준 버튼 램프를 따른다. -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF005FB8" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF0078D4" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF004E96" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <!-- 선택 강조: 그리드/리스트/트리 공통 — Win11 리스트 선택 톤. -->
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFC7E0F7" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF003D75" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF005FB8" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#33005FB8" />

    <!-- 색상 — Neutral. Win11 순정 무채 뉴트럴: 창 배경 #F3F3F3(Mica 근사),
         카드 흰색, 컨트롤 스트로크 #D9D9D9. 이전의 블루 틴트 회색을 제거했다. -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFF3F3F3" />
    <SolidColorBrush x:Key="Brush.Surface" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFFAFAFA" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFF0F0F0" />
    <!-- 그리드 지브라(짝수 행) 전용 — 흰 행과 명도 차가 실제로 보이는 톤
         (고가독성 LOB 원칙: 명도 차 강조). -->
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFF6F6F6" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD9D9D9" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFE8E8E8" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FFA6A6A6" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#FF1B1B1B" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#FF5D5D5D" />
    <SolidColorBrush x:Key="Brush.TextPlaceholder" Color="#FF9B9B9B" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFF2F2F2" />
    <SolidColorBrush x:Key="Brush.DisabledBackground" Color="#FFF5F5F5" />
    <SolidColorBrush x:Key="Brush.DisabledText" Color="#FF9D9D9D" />

    <!-- 색상 — Semantic. Win11(WinUI InfoBar) 시스템 상태색:
         성공 #0F7B0F/#DFF6DD, 주의 #9D5D00/#FFF4CE, 위험 #C42B1C/#FDE7E9. -->
    <SolidColorBrush x:Key="Brush.InfoBackground" Color="#FFEBF3FC" />
    <SolidColorBrush x:Key="Brush.InfoBorder" Color="#FFBBD7F0" />
    <SolidColorBrush x:Key="Brush.InfoText" Color="#FF005FB8" />
    <SolidColorBrush x:Key="Brush.Success" Color="#FF0F7B0F" />
    <SolidColorBrush x:Key="Brush.SuccessHover" Color="#FF0C660C" />
    <SolidColorBrush x:Key="Brush.SuccessPressed" Color="#FF094F09" />
    <SolidColorBrush x:Key="Brush.SuccessBackground" Color="#FFDFF6DD" />
    <SolidColorBrush x:Key="Brush.SuccessBorder" Color="#FFA9D8A4" />
    <SolidColorBrush x:Key="Brush.SuccessText" Color="#FF0F7B0F" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#FF9D5D00" />
    <SolidColorBrush x:Key="Brush.WarningBackground" Color="#FFFFF4CE" />
    <SolidColorBrush x:Key="Brush.WarningBorder" Color="#FFEDD88F" />
    <SolidColorBrush x:Key="Brush.WarningText" Color="#FF9D5D00" />
    <!-- ErrorBorder는 진한 빨강(Danger 버튼 / 필수 표시);
         ErrorBorderSoft는 오류 상태 면에 쓰는 옅은 테두리 색이다. -->
    <!-- 상태색: 성공/경고 (정보=Accent, 오류=ErrorBorder를 겸용) -->
    <SolidColorBrush x:Key="Brush.StatusSuccess" Color="#FF0F7B0F" />
    <SolidColorBrush x:Key="Brush.StatusWarning" Color="#FF9D5D00" />
    <SolidColorBrush x:Key="Brush.ErrorBorder" Color="#FFC42B1C" />
    <!-- ErrorBorderSoft: 오류 상태 면의 옅은 테두리 + 필수 입력 필드의 테두리 표시 겸용 -->
    <SolidColorBrush x:Key="Brush.ErrorBorderSoft" Color="#FFF2B8B2" />
    <SolidColorBrush x:Key="Brush.ErrorBackground" Color="#FFFDE7E9" />
    <SolidColorBrush x:Key="Brush.ErrorText" Color="#FFC42B1C" />
    <SolidColorBrush x:Key="Brush.DangerPressed" Color="#FFA4262C" />
    <SolidColorBrush x:Key="Brush.NeutralBackground" Color="#FFF0F0F0" />
    <SolidColorBrush x:Key="Brush.NeutralText" Color="#FF3B3B3B" />

    <!-- 모달/로딩 배경용 오버레이 스크림(어둡고 반투명). -->
    <SolidColorBrush x:Key="Brush.Scrim" Color="#66101828" />

    <!-- ColorAnimation 대상용 원시 색상 (애니메이션은 Brush가 아닌 Color가 필요) -->
    <Color x:Key="Color.Accent">#FF005FB8</Color>
    <Color x:Key="Color.TrackOff">#FFC8C8C8</Color>

    <!-- 5. 타이포그래피. 폰트: Segoe UI(Fluent 시스템 서체), 한글은 Malgun Gothic
         폴백. 위계는 크기 + 굵기로만 표현한다. -->
    <FontFamily x:Key="Font.Family">Segoe UI, Malgun Gothic</FontFamily>

    <!-- 타입 스케일 (장치 독립 단위; 12 DIU = 9pt, 16 DIU = 12pt).
         컨트롤은 FontSize를 하드코딩하지 않고 이 값을 참조한다. 본문/레이블은 밀도 높은
         데이터 화면을 위해 12(9pt); 제목은 16(12pt)부터 단계적으로 커진다. -->
    <sys:Double x:Key="Font.Size.Helper">12</sys:Double>
    <sys:Double x:Key="Font.Size.Label">12</sys:Double>
    <sys:Double x:Key="Font.Size.Body">12</sys:Double>
    <sys:Double x:Key="Font.Size.BodyLg">12</sys:Double>
    <sys:Double x:Key="Font.Size.Title">16</sys:Double>
    <sys:Double x:Key="Font.Size.Subtitle">16</sys:Double>
    <sys:Double x:Key="Font.Size.Heading">20</sys:Double>
    <sys:Double x:Key="Font.Size.PageTitle">22</sys:Double>
    <sys:Double x:Key="Font.Size.Display">28</sys:Double>

    <!-- 아이콘 글리프 크기 (Segoe MDL2 Assets 등 폰트 아이콘 전용).
         IconSm: 셰브런·정렬 화살표 같은 보조 장식, Icon: 체크 표시 같은 상태 글리프. -->
    <sys:Double x:Key="Font.Size.IconSm">10</sys:Double>
    <sys:Double x:Key="Font.Size.Icon">11</sys:Double>

    <!-- 굵기 규칙: 구조 요소(제목, 필드 레이블, 그리드 헤더)는 SemiBold;
         본문, 데이터, 배지는 Regular 유지. 이 두 가지 굵기만 사용한다. -->
    <Style x:Key="Text.Title" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Title}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Label}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
    </Style>
    <Style x:Key="Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Body}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextPrimary}" />
    </Style>
    <Style x:Key="Text.Helper" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Family}" />
        <Setter Property="FontSize" Value="{StaticResource Font.Size.Helper}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource Brush.TextSecondary}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- 6. 깊이 — 시스템에서 유일하게 허용되는 그림자로, 카드와 오버레이/팝업용. -->
    <DropShadowEffect x:Key="Shadow.Card"
                      Color="#FF000000"
                      Opacity="0.10"
                      BlurRadius="8"
                      ShadowDepth="1"
                      Direction="270" />
    <DropShadowEffect x:Key="Shadow.Popup"
                      Color="#FF101828"
                      Opacity="0.12"
                      BlurRadius="14"
                      ShadowDepth="3"
                      Direction="270" />

</ResourceDictionary>
