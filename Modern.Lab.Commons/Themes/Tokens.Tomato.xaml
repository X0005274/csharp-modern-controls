<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Tomato 테마 오버라이드 — Fluent 공식 레드(#D13438) 램프의        -->
    <!-- 파스텔. 흰 카드 + 로즈 파스텔 배경/테두리.                      -->
    <!-- 텍스트/시맨틱 색은 라이트 값을 공유한다.                        -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Tomato일 때 병합. -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — Fluent red #D13438 램프 (pressed는 redDark #A4262C) -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFD13438" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFDC4A4E" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFA4262C" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFF6D0D2" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF7C1316" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FFD13438" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#33D13438" />

    <!-- Neutral — Fluent 레드 램프의 파스텔 배경·테두리 (카드 표면 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFFAE7E8" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFFDF4F4" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFFDF4F4" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFF6D8DA" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFFCF3F3" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFF0C6C8" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFF7DEDF" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FFE39A9D" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFFBEEEE" />

    <Color x:Key="Color.Accent">#FFD13438</Color>

</ResourceDictionary>
