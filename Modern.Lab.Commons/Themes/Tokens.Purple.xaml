<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Purple 테마 오버라이드 — Fluent 공식 퍼플(#5C2E91, MS 브랜드     -->
    <!-- 퍼플) 램프의 파스텔. 흰 카드 + themeLighter 계열 배경/테두리.    -->
    <!-- 텍스트/시맨틱 색은 라이트 값을 공유한다.                        -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Purple일 때 병합. -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — Fluent themePrimary #5C2E91 램프 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FF5C2E91" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FF6C3CA6" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FF4B2578" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFDCCCF0" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF46226E" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FF5C2E91" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#335C2E91" />

    <!-- Neutral — Fluent 퍼플 램프의 파스텔 배경·테두리 (카드 표면 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFEFE8F8" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFF6F1FB" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFF6F1FB" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFE3D8F4" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFF8F5FC" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFD3C2EC" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFE2D6F3" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FFA98CD9" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFF2ECFA" />

    <Color x:Key="Color.Accent">#FF5C2E91</Color>

</ResourceDictionary>
