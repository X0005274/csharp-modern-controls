<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================= -->
    <!-- Orange 테마 오버라이드 — Fluent 공식 오렌지(#CA5010,             -->
    <!-- sharedOrange20) 램프의 파스텔. 흰 카드 + 웜 파스텔 배경/테두리.  -->
    <!-- 텍스트/시맨틱 색은 라이트 값을 공유한다.                        -->
    <!-- SharedResourceDictionary가 ModernTheme.Mode == Orange일 때 병합. -->
    <!-- ============================================================= -->

    <!-- Primary (액센트) — Fluent #CA5010 램프 -->
    <SolidColorBrush x:Key="Brush.Accent" Color="#FFCA5010" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFD96A2A" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#FFA64009" />
    <SolidColorBrush x:Key="Brush.OnAccent" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Brush.SelectedBackground" Color="#FFF6D9BC" />
    <SolidColorBrush x:Key="Brush.SelectedText" Color="#FF7A3005" />
    <SolidColorBrush x:Key="Brush.FocusBorder" Color="#FFCA5010" />
    <SolidColorBrush x:Key="Brush.FocusRing" Color="#33CA5010" />

    <!-- Neutral — Fluent 오렌지 램프의 파스텔 배경·테두리 (카드 표면 흰색 유지) -->
    <SolidColorBrush x:Key="Brush.Background" Color="#FFFAEADC" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFFDF5EC" />
    <SolidColorBrush x:Key="Brush.HeaderBackground" Color="#FFFDF5EC" />
    <SolidColorBrush x:Key="Brush.GridHeaderBackground" Color="#FFF4DCC4" />
    <SolidColorBrush x:Key="Brush.GridRowAlt" Color="#FFFCF6EE" />
    <SolidColorBrush x:Key="Brush.Border" Color="#FFEFD0B2" />
    <SolidColorBrush x:Key="Brush.BorderSubtle" Color="#FFF6E2CD" />
    <SolidColorBrush x:Key="Brush.BorderHover" Color="#FFE0A671" />
    <SolidColorBrush x:Key="Brush.HoverBackground" Color="#FFFBF0E4" />

    <Color x:Key="Color.Accent">#FFCA5010</Color>

</ResourceDictionary>
